# Supabase — Créer un projet sur https://supabase.com et copier les valeurs
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=XXXX
SUPABASE_SERVICE_ROLE_KEY=XXXX

# Resend — https://resend.com
RESEND_API_KEY=re_XXXX

# Expéditeur unique de TOUS les emails transactionnels (contact, consignation,
# vente, confirmation de commande). Optionnel : sans cette variable, fallback
# sur 'CGWS <onboarding@resend.dev>' (domaine de test Resend, ne délivre qu'à
# l'adresse du compte Resend).
# ⚠️ PRÉREQUIS avant de basculer sur 'CGWS <noreply@cgws.fr>' : le domaine
# cgws.fr doit être VÉRIFIÉ dans Resend (enregistrements DNS chez le registrar,
# Dashboard Resend → Domains). Sinon, tous les envois échouent.
# CGWS_EMAIL_FROM=CGWS <noreply@cgws.fr>

# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY : clé secrète (serveur uniquement, sk_...)
# NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY : clé publiable (client, pk_...) — monte le Checkout embarqué
# STRIPE_WEBHOOK_SECRET : signing secret de l'endpoint webhook
# (Dashboard → Developers → Webhooks → endpoint /api/checkout/webhook, événements :
#  checkout.session.completed, checkout.session.async_payment_succeeded,
#  checkout.session.async_payment_failed, checkout.session.expired)
STRIPE_SECRET_KEY=sk_XXXX
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# PostHog — https://eu.posthog.com (hébergement UE obligatoire, cf. Sprint 11 / E12)
# NUXT_PUBLIC_POSTHOG_KEY : clé PROJET (publique, phc_...) — utilisée par posthog-js côté client
# NUXT_PUBLIC_POSTHOG_HOST : hôte UE
# POSTHOG_PERSONAL_API_KEY : clé personnelle (SECRÈTE, phx_...) — API privée serveur/CLI
#   uniquement (config funnels/dashboards US-105). Ne JAMAIS la mettre en NUXT_PUBLIC_*.
NUXT_PUBLIC_POSTHOG_KEY=phc_XXXX
NUXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_PERSONAL_API_KEY=phx_XXXX

# Site
NUXT_PUBLIC_SITE_URL=https://cgws.fr
