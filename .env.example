# Supabase — Créer un projet sur https://supabase.com et copier les valeurs
SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_ANON_KEY=XXXX
SUPABASE_SERVICE_ROLE_KEY=XXXX

# Resend — https://resend.com
RESEND_API_KEY=re_XXXX

# Stripe — https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY : clé secrète (serveur uniquement, sk_...)
# NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY : clé publiable (client, pk_...) — monte le Checkout embarqué
# STRIPE_WEBHOOK_SECRET : signing secret de l'endpoint webhook
# (Dashboard → Developers → Webhooks → endpoint /api/checkout/webhook, événements :
#  checkout.session.completed, checkout.session.async_payment_succeeded,
#  checkout.session.async_payment_failed, checkout.session.expired)
STRIPE_SECRET_KEY=sk_XXXX
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_XXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXX

# Site
NUXT_PUBLIC_SITE_URL=https://cgws.fr
